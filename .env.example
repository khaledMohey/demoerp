# Local SQLite (default)
DATABASE_URL="file:./dev.db"

# Or PostgreSQL with docker compose:
# DATABASE_URL="postgresql://erp:erp_secret@localhost:5432/demoerp?schema=public"
# Then change prisma/schema.prisma datasource provider to "postgresql"

AUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
